{% extends 'base.html.twig' %}

{% block title %}Sign Up - Real Scout{% endblock %}

{% block footer_nav %}{% endblock %}

{% block body %}
<div class="min-h-screen bg-white flex flex-col items-center justify-start overflow-y-auto pb-10">
    <div class="w-full max-w-[500px] flex flex-col items-center">
        {# Onboarding Image #}
        <div class="relative w-full aspect-[3/4] md:aspect-square mt-4">
            <img src="{{ asset('images/onboarding.png') }}" alt="Onboarding" class="w-full h-full object-contain">
        </div>

        <div class="px-10 mt-6 w-full flex flex-col items-center">
            <p class="text-sm uppercase font-rubik text-black-200 tracking-widest">
                Welcome To Real Scout
            </p>

            <h1 class="text-2xl font-rubik-bold text-black-300 text-center mt-2 leading-tight">
                Let's Get You Closer To <br />
                <span class="text-primary-300">Your Ideal Home</span>
            </h1>

            <form method="post" class="w-full mt-8 flex flex-col gap-4">
                <div class="flex gap-4">
                    <div class="flex-1 flex flex-col gap-1">
                        <label for="name" class="text-xs font-rubik-medium text-black-200 ml-1">Name</label>
                        <input
                            type="text"
                            name="name"
                            id="name"
                            required
                            class="bg-gray-50 border border-gray-100 rounded-xl px-4 py-3 outline-none focus:border-primary-300 transition-colors font-rubik text-sm"
                            placeholder="First Name"
                        >
                    </div>
                    <div class="flex-1 flex flex-col gap-1">
                        <label for="subname" class="text-xs font-rubik-medium text-black-200 ml-1">Subname</label>
                        <input
                            type="text"
                            name="subname"
                            id="subname"
                            required
                            class="bg-gray-50 border border-gray-100 rounded-xl px-4 py-3 outline-none focus:border-primary-300 transition-colors font-rubik text-sm"
                            placeholder="Last Name"
                        >
                    </div>
                </div>

                <div class="flex flex-col gap-1">
                    <label for="email" class="text-xs font-rubik-medium text-black-200 ml-1">Email</label>
                    <input
                        type="email"
                        name="email"
                        id="email"
                        required
                        class="bg-gray-50 border border-gray-100 rounded-xl px-4 py-3 outline-none focus:border-primary-300 transition-colors font-rubik text-sm"
                        placeholder="example@mail.com"
                    >
                </div>

                <div class="flex flex-col gap-1">
                    <label for="password" class="text-xs font-rubik-medium text-black-200 ml-1">Password</label>
                    <input
                        type="password"
                        name="password"
                        id="password"
                        required
                        minlength="8"
                        class="bg-gray-50 border border-gray-100 rounded-xl px-4 py-3 outline-none focus:border-primary-300 transition-colors font-rubik text-sm"
                        placeholder="••••••••"
                    >
                </div>

                <button
                    type="submit"
                    class="bg-primary-300 rounded-full w-full py-4 mt-4 shadow-lg shadow-primary-300/20 hover:bg-primary-300/90 transition-all duration-300 text-white font-rubik-bold text-lg"
                >
                    Create Account
                </button>
            </form>

            <div class="mt-8 flex flex-row items-center gap-2">
                <p class="text-sm font-rubik text-black-100">Already have an account?</p>
                <a href="{{ path('app_login') }}" class="text-sm font-rubik-bold text-primary-300 hover:text-primary-300/80 transition-colors">Sign In</a>
            </div>
            
            <p class="text-[10px] text-center text-black-100 mt-10 opacity-60">
                By continuing, you agree to our Terms of Service and Privacy Policy.
            </p>
        </div>
    </div>
</div>
{% endblock %}
