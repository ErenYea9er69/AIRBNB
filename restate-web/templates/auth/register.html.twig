{% extends 'base.html.twig' %}

{% block title %}Sign Up - Real Scout{% endblock %}

{% block footer_nav %}{% endblock %}

{% block body %}
<style>
    .auth-page { display:grid; grid-template-columns:1fr 1fr; min-height:100vh; }
    .auth-visual { position:relative; overflow:hidden; display:flex; align-items:center; justify-content:center; }
    .auth-visual-bg { position:absolute; inset:0; }
    .auth-visual-bg img { width:100%; height:100%; object-fit:cover; display:block; }
    .auth-visual-overlay { position:absolute; inset:0; background:linear-gradient(135deg, rgba(0,97,255,0.85) 0%, rgba(0,40,120,0.9) 100%); }
    .auth-visual-content { position:relative; z-index:2; padding:60px; max-width:480px; }
    .auth-visual-logo { font-family:'Rubik-Bold',sans-serif; font-size:28px; font-weight:700; color:white; margin-bottom:48px; display:flex; align-items:center; gap:10px; }
    .auth-visual-logo span { font-size:32px; }
    .auth-visual-title { font-family:'Rubik-Bold',sans-serif; font-size:42px; font-weight:700; color:white; line-height:1.15; margin:0; }
    .auth-visual-desc { font-family:'Rubik',sans-serif; font-size:16px; color:rgba(255,255,255,0.75); line-height:1.7; margin:20px 0 0; }
    .auth-visual-features { margin-top:40px; padding-top:32px; border-top:1px solid rgba(255,255,255,0.15); display:flex; flex-direction:column; gap:16px; }
    .auth-feature { display:flex; align-items:center; gap:14px; }
    .auth-feature-icon { width:40px; height:40px; border-radius:12px; background:rgba(255,255,255,0.12); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .auth-feature-icon span { font-size:18px; }
    .auth-feature-text { font-family:'Rubik-Medium',sans-serif; font-size:14px; color:rgba(255,255,255,0.85); font-weight:500; }

    .auth-form-side { display:flex; align-items:center; justify-content:center; padding:48px; background:white; overflow-y:auto; }
    .auth-form-container { width:100%; max-width:460px; }
    .auth-form-header { margin-bottom:32px; }
    .auth-form-header p { font-family:'Rubik',sans-serif; font-size:14px; color:#8C8E98; margin:0 0 8px; }
    .auth-form-header h1 { font-family:'Rubik-Bold',sans-serif; font-size:30px; font-weight:700; color:#191D31; margin:0; }
    .auth-form-header h1 span { color:#0061FF; }

    .auth-field { margin-bottom:18px; }
    .auth-label { display:block; font-family:'Rubik-Medium',sans-serif; font-size:13px; font-weight:500; color:#666876; margin-bottom:8px; }
    .auth-input { width:100%; padding:14px 18px; background:#f8f9fc; border:1.5px solid rgba(0,97,255,0.08); border-radius:14px; font-family:'Rubik',sans-serif; font-size:15px; color:#191D31; outline:none; transition:all 0.25s; box-sizing:border-box; }
    .auth-input:focus { border-color:#0061FF; background:white; box-shadow:0 0 0 4px rgba(0,97,255,0.08); }
    .auth-input::placeholder { color:#b0b3bf; }

    .auth-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; }

    .auth-radio-group { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-top:8px; }
    .auth-radio-label { display:flex; align-items:center; gap:10px; padding:14px 18px; background:#f8f9fc; border:1.5px solid rgba(0,97,255,0.08); border-radius:14px; cursor:pointer; transition:all 0.25s; font-family:'Rubik-Medium',sans-serif; font-size:14px; color:#191D31; font-weight:500; }
    .auth-radio-label:has(input:checked) { border-color:#0061FF; background:rgba(0,97,255,0.04); box-shadow:0 0 0 3px rgba(0,97,255,0.08); }
    .auth-radio-label input { accent-color:#0061FF; width:18px; height:18px; }
    .auth-radio-desc { font-family:'Rubik',sans-serif; font-size:11px; color:#8C8E98; margin-top:2px; font-weight:400; }

    .auth-submit { display:block; width:100%; padding:16px; background:#0061FF; color:white; font-family:'Rubik-Bold',sans-serif; font-size:16px; font-weight:700; border:none; border-radius:14px; cursor:pointer; transition:all 0.3s; box-shadow:0 6px 20px rgba(0,97,255,0.3); margin-top:24px; }
    .auth-submit:hover { background:#0050d4; transform:translateY(-1px); box-shadow:0 8px 28px rgba(0,97,255,0.4); }
    .auth-submit:active { transform:scale(0.98); }

    .auth-footer { text-align:center; margin-top:24px; }
    .auth-footer p { font-family:'Rubik',sans-serif; font-size:14px; color:#8C8E98; margin:0; }
    .auth-footer a { color:#0061FF; font-family:'Rubik-Bold',sans-serif; font-weight:700; text-decoration:none; transition:color 0.2s; }
    .auth-footer a:hover { color:#0050d4; }
    .auth-terms { text-align:center; margin-top:24px; font-family:'Rubik',sans-serif; font-size:11px; color:#b0b3bf; }

    @media (max-width:900px) {
        .auth-page { grid-template-columns:1fr; }
        .auth-visual { display:none; }
        .auth-form-side { padding:32px 24px; }
        .auth-row { grid-template-columns:1fr; }
    }
</style>

<div class="auth-page">
    {# ─── LEFT: Visual Panel ─── #}
    <div class="auth-visual">
        <div class="auth-visual-bg">
            <img src="{{ asset('images/new-york.png') }}" alt="Real Estate">
        </div>
        <div class="auth-visual-overlay"></div>
        <div class="auth-visual-content">
            <div class="auth-visual-logo">
                <span>🏠</span> Real Scout
            </div>
            <h2 class="auth-visual-title">Start Your Real Estate Journey</h2>
            <p class="auth-visual-desc">
                Whether you're buying your first home or listing properties as an agent, Real Scout is your trusted partner.
            </p>
            <div class="auth-visual-features">
                <div class="auth-feature">
                    <div class="auth-feature-icon"><span>🔍</span></div>
                    <span class="auth-feature-text">Browse thousands of verified listings</span>
                </div>
                <div class="auth-feature">
                    <div class="auth-feature-icon"><span>🏡</span></div>
                    <span class="auth-feature-text">List your properties as a seller</span>
                </div>
                <div class="auth-feature">
                    <div class="auth-feature-icon"><span>❤️</span></div>
                    <span class="auth-feature-text">Save and track your favorites</span>
                </div>
                <div class="auth-feature">
                    <div class="auth-feature-icon"><span>📊</span></div>
                    <span class="auth-feature-text">Dedicated seller dashboard & analytics</span>
                </div>
            </div>
        </div>
    </div>

    {# ─── RIGHT: Register Form ─── #}
    <div class="auth-form-side">
        <div class="auth-form-container">
            <div class="auth-form-header">
                <p>Get started for free</p>
                <h1>Create your <span>account</span></h1>
            </div>

            <form method="post">
                <div class="auth-row">
                    <div class="auth-field">
                        <label for="name" class="auth-label">First Name</label>
                        <input type="text" name="name" id="name" class="auth-input"
                               required placeholder="John">
                    </div>
                    <div class="auth-field">
                        <label for="subname" class="auth-label">Last Name</label>
                        <input type="text" name="subname" id="subname" class="auth-input"
                               required placeholder="Doe">
                    </div>
                </div>

                <div class="auth-field">
                    <label for="email" class="auth-label">Email Address</label>
                    <input type="email" name="email" id="email" class="auth-input"
                           required placeholder="you@example.com">
                </div>

                <div class="auth-field">
                    <label for="password" class="auth-label">Password</label>
                    <input type="password" name="password" id="password" class="auth-input"
                           required minlength="8" placeholder="Minimum 8 characters">
                </div>

                <div class="auth-field">
                    <label class="auth-label">I am a...</label>
                    <div class="auth-radio-group">
                        <label class="auth-radio-label">
                            <input type="radio" name="user_type" value="buyer" checked>
                            <div>
                                <div>Buyer / Renter</div>
                                <div class="auth-radio-desc">Looking for properties</div>
                            </div>
                        </label>
                        <label class="auth-radio-label">
                            <input type="radio" name="user_type" value="seller">
                            <div>
                                <div>Seller / Agent</div>
                                <div class="auth-radio-desc">Listing properties</div>
                            </div>
                        </label>
                    </div>
                </div>

                <button type="submit" class="auth-submit">Create Account</button>
            </form>

            <div class="auth-footer">
                <p>Already have an account? <a href="{{ path('app_login') }}">Sign in</a></p>
            </div>

            <p class="auth-terms">By creating an account, you agree to our Terms of Service and Privacy Policy.</p>
        </div>
    </div>
</div>
{% endblock %}
