{% extends 'base.html.twig' %}

{% block title %}{{ property.title }} - Real Scout{% endblock %}

{% block footer_nav %}{% endblock %}

{% block body %}
<main style="max-width:900px; margin:0 auto; padding-bottom:120px; background:white; min-height:100vh;">

    {# ═══════════════════════════════════════════════════════════
       HERO IMAGE with overlaid navigation
    ═══════════════════════════════════════════════════════════ #}
    <div style="position:relative; width:100%; height:420px; overflow:hidden;">
        <img src="{{ asset(property.image) }}" alt="{{ property.title }}"
             style="width:100%; height:100%; object-fit:cover; display:block;">
        
        {# Gradient overlay for readability #}
        <div style="position:absolute; top:0; left:0; right:0; height:120px; background:linear-gradient(to bottom, rgba(0,0,0,0.35), transparent); pointer-events:none;"></div>

        {# Top navigation bar #}
        <div style="position:absolute; top:20px; left:20px; right:20px; display:flex; align-items:center; justify-content:space-between; z-index:10;">
            <button onclick="window.history.back()" 
                    style="width:44px; height:44px; border-radius:50%; background:#0061FF; border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; box-shadow:0 4px 15px rgba(0,97,255,0.4); transition:transform 0.2s;"
                    onmousedown="this.style.transform='scale(0.92)'" onmouseup="this.style.transform='scale(1)'">
                <img src="{{ asset('icons/back-arrow.png') }}" style="width:18px; height:18px; filter:brightness(10);">
            </button>
            <div style="display:flex; gap:12px;">
                <button onclick="toggleFavorite({{ property.id }}, this)"
                        style="width:44px; height:44px; border-radius:50%; background:rgba(255,255,255,0.25); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,0.3); cursor:pointer; display:flex; align-items:center; justify-content:center; transition:transform 0.2s;"
                        onmousedown="this.style.transform='scale(0.92)'" onmouseup="this.style.transform='scale(1)'">
                    <img src="{{ asset('icons/heart.png') }}" id="heart-icon"
                         style="width:22px; height:22px; {% if app.user and property in app.user.savedProperties %}filter:none;{% else %}filter:brightness(10);{% endif %}">
                </button>
                <button style="width:44px; height:44px; border-radius:50%; background:rgba(255,255,255,0.25); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px); border:1px solid rgba(255,255,255,0.3); cursor:pointer; display:flex; align-items:center; justify-content:center;">
                    <img src="{{ asset('icons/send.png') }}" style="width:20px; height:20px; filter:brightness(10);">
                </button>
            </div>
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════
       PROPERTY INFO SECTION
    ═══════════════════════════════════════════════════════════ #}
    <div style="padding:28px 24px 0;">

        {# Title row #}
        <h1 style="font-family:'Rubik-Bold',sans-serif; font-size:26px; font-weight:700; color:#191D31; margin:0; line-height:1.2;">
            {{ property.title }}
        </h1>

        {# Badge + Rating row #}
        <div style="display:flex; align-items:center; gap:12px; margin-top:10px; flex-wrap:wrap;">
            <span style="background:rgba(0,97,255,0.06); color:#0061FF; font-family:'Rubik-Bold',sans-serif; font-size:11px; font-weight:700; padding:5px 14px; border-radius:20px; text-transform:uppercase; letter-spacing:1.5px;">
                {{ property.category.name|default('Property') }}
            </span>
            <div style="display:flex; align-items:center; gap:4px;">
                <img src="{{ asset('icons/star.png') }}" style="width:16px; height:16px;">
                <span style="font-family:'Rubik-Medium',sans-serif; font-size:14px; color:#666876; font-weight:500;">
                    {{ property.rating }} ({{ property.reviews|length }} reviews)
                </span>
            </div>
        </div>

        {# ═══════════════════════════════════════════════════════════
           FACILITIES GRID — 4 columns
        ═══════════════════════════════════════════════════════════ #}
        <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-top:28px; padding:20px; background:white; border-radius:20px; border:1px solid rgba(0,97,255,0.08); box-shadow:0 2px 12px rgba(0,0,0,0.04);">
            <div style="display:flex; flex-direction:column; align-items:center; gap:6px;">
                <div style="width:44px; height:44px; border-radius:50%; background:rgba(0,97,255,0.06); display:flex; align-items:center; justify-content:center;">
                    <img src="{{ asset('icons/bed.png') }}" style="width:22px; height:22px;">
                </div>
                <span style="font-family:'Rubik-Medium',sans-serif; font-size:12px; color:#191D31; font-weight:500;">{{ property.bedrooms }} Beds</span>
            </div>
            <div style="display:flex; flex-direction:column; align-items:center; gap:6px;">
                <div style="width:44px; height:44px; border-radius:50%; background:rgba(0,97,255,0.06); display:flex; align-items:center; justify-content:center;">
                    <img src="{{ asset('icons/bath.png') }}" style="width:22px; height:22px;">
                </div>
                <span style="font-family:'Rubik-Medium',sans-serif; font-size:12px; color:#191D31; font-weight:500;">{{ property.bathrooms }} Bath</span>
            </div>
            <div style="display:flex; flex-direction:column; align-items:center; gap:6px;">
                <div style="width:44px; height:44px; border-radius:50%; background:rgba(0,97,255,0.06); display:flex; align-items:center; justify-content:center;">
                    <img src="{{ asset('icons/area.png') }}" style="width:22px; height:22px;">
                </div>
                <span style="font-family:'Rubik-Medium',sans-serif; font-size:12px; color:#191D31; font-weight:500;">{{ property.area }} sqft</span>
            </div>
            <div style="display:flex; flex-direction:column; align-items:center; gap:6px;">
                <div style="width:44px; height:44px; border-radius:50%; background:rgba(0,97,255,0.06); display:flex; align-items:center; justify-content:center;">
                    <img src="{{ asset('icons/star.png') }}" style="width:22px; height:22px;">
                </div>
                <span style="font-family:'Rubik-Medium',sans-serif; font-size:12px; color:#191D31; font-weight:500;">{{ property.rating }} Star</span>
            </div>
        </div>

        {# ═══════════════════════════════════════════════════════════
           AGENT CARD
        ═══════════════════════════════════════════════════════════ #}
        <div style="margin-top:36px; padding-top:28px; border-top:1px solid rgba(0,97,255,0.08);">
            <h2 style="font-family:'Rubik-Bold',sans-serif; font-size:20px; font-weight:700; color:#191D31; margin:0 0 16px;">Agent</h2>
            <div style="display:flex; align-items:center; justify-content:space-between;">
                <div style="display:flex; align-items:center; gap:14px;">
                    <div style="width:56px; height:56px; border-radius:50%; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,0.1); flex-shrink:0;">
                        <img src="{{ asset(property.agent.avatar|default('images/japan.png')) }}" 
                             style="width:56px; height:56px; object-fit:cover; display:block;">
                    </div>
                    <div>
                        <p style="font-family:'Rubik-Bold',sans-serif; font-size:17px; font-weight:700; color:#191D31; margin:0;">
                            {{ property.agent.name|default('Real Scout Agent') }}
                        </p>
                        <p style="font-family:'Rubik',sans-serif; font-size:13px; color:#8C8E98; margin:4px 0 0;">
                            Owner & Sales Manager
                        </p>
                    </div>
                </div>
                <div style="display:flex; align-items:center; gap:16px;">
                    <a href="#" style="display:flex; align-items:center; justify-content:center; width:40px; height:40px; border-radius:50%; background:rgba(0,97,255,0.06); transition:background 0.2s;"
                       onmouseover="this.style.background='rgba(0,97,255,0.12)'" onmouseout="this.style.background='rgba(0,97,255,0.06)'">
                        <img src="{{ asset('icons/chat.png') }}" style="width:20px; height:20px;">
                    </a>
                    <a href="#" style="display:flex; align-items:center; justify-content:center; width:40px; height:40px; border-radius:50%; background:rgba(0,97,255,0.06); transition:background 0.2s;"
                       onmouseover="this.style.background='rgba(0,97,255,0.12)'" onmouseout="this.style.background='rgba(0,97,255,0.06)'">
                        <img src="{{ asset('icons/phone.png') }}" style="width:20px; height:20px;">
                    </a>
                </div>
            </div>
        </div>

        {# ═══════════════════════════════════════════════════════════
           DESCRIPTION
        ═══════════════════════════════════════════════════════════ #}
        <div style="margin-top:36px;">
            <h2 style="font-family:'Rubik-Bold',sans-serif; font-size:20px; font-weight:700; color:#191D31; margin:0 0 12px;">Description</h2>
            <p style="font-family:'Rubik',sans-serif; font-size:15px; color:#666876; line-height:1.7; margin:0;">
                {{ property.description|default('No description provided for this luxury property.') }}
            </p>
        </div>

        {# ═══════════════════════════════════════════════════════════
           GALLERY
        ═══════════════════════════════════════════════════════════ #}
        {% if property.galleries|length > 0 %}
        <div style="margin-top:36px;">
            <h2 style="font-family:'Rubik-Bold',sans-serif; font-size:20px; font-weight:700; color:#191D31; margin:0 0 16px;">Gallery</h2>
            <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:12px;">
                {% for image in property.galleries %}
                    <img src="{{ asset(image.image) }}" 
                         style="width:100%; height:140px; border-radius:16px; object-fit:cover; box-shadow:0 2px 8px rgba(0,0,0,0.06); transition:transform 0.3s;"
                         onmouseover="this.style.transform='scale(1.03)'" onmouseout="this.style.transform='scale(1)'">
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {# ═══════════════════════════════════════════════════════════
           REVIEWS
        ═══════════════════════════════════════════════════════════ #}
        <div style="margin-top:36px; padding-bottom:40px;">
            <div style="display:flex; align-items:center; justify-content:space-between;">
                <div style="display:flex; align-items:center; gap:8px;">
                    <img src="{{ asset('icons/star.png') }}" style="width:22px; height:22px;">
                    <h2 style="font-family:'Rubik-Bold',sans-serif; font-size:20px; font-weight:700; color:#191D31; margin:0;">
                        {{ property.rating }} ({{ property.reviews|length }} reviews)
                    </h2>
                </div>
                <a href="#" style="font-family:'Rubik-Bold',sans-serif; font-size:15px; font-weight:700; color:#0061FF; text-decoration:none;">See All</a>
            </div>
            
            <div style="margin-top:24px; display:flex; flex-direction:column; gap:24px;">
                {% for review in property.reviews %}
                    <div style="padding:20px; background:#f8f9fc; border-radius:16px;">
                        <div style="display:flex; align-items:center; justify-content:space-between;">
                            <div style="display:flex; align-items:center; gap:12px;">
                                <img src="{{ asset(review.user.avatar|default('images/avatar.png')) }}" 
                                     style="width:44px; height:44px; border-radius:50%; object-fit:cover;">
                                <span style="font-family:'Rubik-Bold',sans-serif; font-size:15px; font-weight:700; color:#191D31;">
                                    {{ review.user.name|default('Anonymous') }}
                                </span>
                            </div>
                            <div style="display:flex; align-items:center; gap:4px; background:rgba(0,97,255,0.06); padding:4px 12px; border-radius:20px;">
                                <img src="{{ asset('icons/star.png') }}" style="width:12px; height:12px;">
                                <span style="font-family:'Rubik-Bold',sans-serif; font-size:12px; font-weight:700; color:#0061FF;">{{ review.rating }}</span>
                            </div>
                        </div>
                        <p style="font-family:'Rubik',sans-serif; font-size:14px; color:#666876; margin:12px 0 0; line-height:1.6;">
                            {{ review.review }}
                        </p>
                    </div>
                {% else %}
                    <p style="font-family:'Rubik',sans-serif; font-size:14px; color:#8C8E98; font-style:italic;">No reviews yet for this property.</p>
                {% endfor %}
            </div>
        </div>
    </div>

    {# ═══════════════════════════════════════════════════════════
       BOTTOM CTA BAR — Fixed
    ═══════════════════════════════════════════════════════════ #}
    <div style="position:fixed; bottom:0; left:0; right:0; background:white; border-top:1px solid rgba(0,97,255,0.1); padding:18px 24px; z-index:50; box-shadow:0 -4px 20px rgba(0,0,0,0.06); border-radius:24px 24px 0 0;">
        <div style="max-width:900px; margin:0 auto; display:flex; align-items:center; justify-content:space-between;">
            <div>
                <p style="font-family:'Rubik-Medium',sans-serif; font-size:10px; font-weight:500; color:#8C8E98; text-transform:uppercase; letter-spacing:2px; margin:0;">Price</p>
                <p style="font-family:'Rubik-Bold',sans-serif; font-size:24px; font-weight:700; color:#0061FF; margin:2px 0 0;">${{ property.price|number_format }}</p>
            </div>
            <button style="background:#0061FF; color:white; font-family:'Rubik-Bold',sans-serif; font-size:17px; font-weight:700; padding:16px 40px; border-radius:50px; border:none; cursor:pointer; box-shadow:0 6px 20px rgba(0,97,255,0.35); transition:all 0.3s;"
                    onmouseover="this.style.background='#0050d4'; this.style.transform='translateY(-1px)'; this.style.boxShadow='0 8px 25px rgba(0,97,255,0.45)'"
                    onmouseout="this.style.background='#0061FF'; this.style.transform='translateY(0)'; this.style.boxShadow='0 6px 20px rgba(0,97,255,0.35)'"
                    onmousedown="this.style.transform='scale(0.97)'" onmouseup="this.style.transform='scale(1)'">
                Booking Now
            </button>
        </div>
    </div>
</main>

<script>
function toggleFavorite(propertyId, buttonElement) {
    fetch(`/user/favorite/${propertyId}`, {
        method: 'POST',
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(response => {
        if (response.status === 401) {
            window.location.href = "{{ path('app_login') }}";
            return;
        }
        return response.json();
    })
    .then(data => {
        if (data && data.success) {
            const icon = document.getElementById('heart-icon');
            icon.style.filter = data.isFavorite ? 'none' : 'brightness(10)';
        }
    })
    .catch(error => console.error('Error toggling favorite:', error));
}
</script>
{% endblock %}
