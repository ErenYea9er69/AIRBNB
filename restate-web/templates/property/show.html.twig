{% extends 'base.html.twig' %}

{% block title %}{{ property.title }} - Real Scout{% endblock %}

{% block footer_nav %}{% endblock %}

{% block body %}
<main class="max-w-7xl mx-auto pb-32">
    <div class="relative w-full h-[350px] md:h-[500px]">
        <img src="{{ asset(property.image) }}" alt="property" class="w-full h-full object-cover">
        
        {# Overlay Top Nav #}
        <div class="absolute top-10 left-6 right-6 flex items-center justify-between">
            <button onclick="window.history.back()" class="bg-primary-300 w-10 h-10 rounded-full flex items-center justify-center shadow-lg">
                <img src="{{ asset('icons/back-arrow.png') }}" class="w-5 h-5 brightness-200">
            </button>
            <div class="flex gap-4">
                <button class="bg-white/30 backdrop-blur-md w-10 h-10 rounded-full flex items-center justify-center border border-white/20">
                    <img src="{{ asset('icons/heart.png') }}" class="w-6 h-6 brightness-200">
                </button>
                <button class="bg-white/30 backdrop-blur-md w-10 h-10 rounded-full flex items-center justify-center border border-white/20">
                    <img src="{{ asset('icons/send.png') }}" class="w-5 h-5 brightness-200">
                </button>
            </div>
        </div>
    </div>

    <div class="px-6 mt-8">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-2">
            <div class="flex flex-col">
                <h1 class="text-2xl font-rubik-bold text-black-300">{{ property.title }}</h1>
                <div class="flex flex-row items-center gap-2 mt-2">
                    <div class="bg-primary-100 px-3 py-1 rounded-full">
                        <span class="text-[10px] font-rubik-bold text-primary-300 uppercase tracking-widest">{{ property.category.name|default('Property') }}</span>
                    </div>
                    <div class="flex flex-row items-center gap-1">
                        <img src="{{ asset('icons/star.png') }}" class="w-4 h-4">
                        <span class="text-sm font-rubik-medium text-black-200">{{ property.rating }} ({{ property.reviews|length }} reviews)</span>
                    </div>
                </div>
            </div>
        </div>

        {# Facilities #}
        <div class="grid grid-cols-4 gap-2 mt-8 bg-white p-4 rounded-2xl shadow-sm border border-primary-100/50">
           <div class="flex flex-col items-center justify-center gap-1">
                <div class="bg-primary-100 p-2.5 rounded-full">
                    <img src="{{ asset('icons/bed.png') }}" class="w-5 h-5">
                </div>
                <span class="text-[10px] font-rubik-medium text-black-300">{{ property.bedrooms }} Beds</span>
           </div>
           <div class="flex flex-col items-center justify-center gap-1">
                <div class="bg-primary-100 p-2.5 rounded-full">
                    <img src="{{ asset('icons/bath.png') }}" class="w-5 h-5">
                </div>
                <span class="text-[10px] font-rubik-medium text-black-300">{{ property.bathrooms }} Bath</span>
           </div>
           <div class="flex flex-col items-center justify-center gap-1">
                <div class="bg-primary-100 p-2.5 rounded-full">
                    <img src="{{ asset('icons/area.png') }}" class="w-5 h-5">
                </div>
                <span class="text-[10px] font-rubik-medium text-black-300">{{ property.area }} sqft</span>
           </div>
           <div class="flex flex-col items-center justify-center gap-1">
                <div class="bg-primary-100 p-2.5 rounded-full">
                    <img src="{{ asset('icons/star.png') }}" class="w-5 h-5">
                </div>
                <span class="text-[10px] font-rubik-medium text-black-300">{{ property.rating }} Star</span>
           </div>
        </div>

        {# Agent #}
        <div class="mt-10 pt-10 border-t border-primary-100">
            <h2 class="text-xl font-rubik-bold text-black-300">Agent</h2>
            <div class="flex flex-row items-center justify-between mt-4">
                 <div class="flex flex-row items-center">
                    <div class="w-14 h-14 rounded-full overflow-hidden shadow-sm">
                        <img src="{{ asset(property.agent.avatar|default('images/japan.png')) }}" class="w-full h-full object-cover">
                    </div>
                    <div class="ml-4 flex flex-col justify-center">
                        <p class="text-lg font-rubik-bold text-black-300">{{ property.agent.name|default('Real Scout Agent') }}</p>
                        <p class="text-sm font-rubik text-black-200">Owner & Sales Manager</p>
                    </div>
                 </div>
                 <div class="flex flex-row items-center gap-4">
                    <img src="{{ asset('icons/chat.png') }}" class="w-6 h-6 hover:opacity-70 cursor-pointer">
                    <img src="{{ asset('icons/phone.png') }}" class="w-6 h-6 hover:opacity-70 cursor-pointer">
                 </div>
            </div>
        </div>

        {# Description #}
        <div class="mt-10">
            <h2 class="text-xl font-rubik-bold text-black-300">Description</h2>
            <p class="text-black-200 text-base font-rubik mt-3 leading-relaxed">
                {{ property.description|default('No description provided for this luxury property.') }}
            </p>
        </div>

        {# Gallery #}
        {% if property.galleries|length > 0 %}
        <div class="mt-10">
            <h2 class="text-xl font-rubik-bold text-black-300">Gallery</h2>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mt-5">
                {% for image in property.galleries %}
                    <img src="{{ asset(image.image) }}" class="w-full h-32 md:h-48 rounded-2xl object-cover shadow-sm">
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {# Reviews #}
        <div class="mt-10 mb-20 pb-20">
             <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                    <img src="{{ asset('icons/star.png') }}" class="w-6 h-6">
                    <h2 class="text-xl font-rubik-bold text-black-300">{{ property.rating }} ({{ property.reviews|length }} reviews)</h2>
                </div>
                <a href="#" class="text-base font-rubik-bold text-primary-300">See All</a>
            </div>
            
            <div class="mt-8 flex flex-col gap-8">
                {% for review in property.reviews %}
                    <div class="flex flex-col items-start">
                        <div class="flex flex-row items-center justify-between w-full">
                            <div class="flex flex-row items-center">
                                <img src="{{ asset(review.avatar) }}" class="w-12 h-12 rounded-full">
                                <span class="text-base font-rubik-bold text-black-300 ml-3">{{ review.name }}</span>
                            </div>
                            <div class="bg-primary-100 flex flex-row items-center gap-1 px-3 py-1 rounded-full">
                                <img src="{{ asset('icons/star.png') }}" class="w-3 h-3">
                                <span class="text-xs font-rubik-bold text-primary-300">{{ review.rating }}</span>
                            </div>
                        </div>
                        <p class="text-black-200 text-base font-rubik mt-3">{{ review.review }}</p>
                        <div class="flex flex-row items-center justify-between w-full mt-4">
                            <div class="flex flex-row items-center">
                                <img src="{{ asset('icons/heart.png') }}" class="w-5 h-5 opacity-40">
                                <span class="text-sm font-rubik-medium text-black-300 ml-2">120</span>
                            </div>
                            <span class="text-xs text-black-100 font-rubik">2 days ago</span>
                        </div>
                    </div>
                {% else %}
                    <p class="text-black-100 italic">No reviews yet for this property.</p>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Bottom CTA #}
    <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-primary-200 px-6 py-6 z-50 rounded-t-3xl shadow-2xl">
        <div class="max-w-7xl mx-auto flex flex-row items-center justify-between">
             <div class="flex flex-col items-start">
                <p class="text-[10px] font-rubik-medium text-black-100 uppercase tracking-widest">Price</p>
                <p class="text-2xl font-rubik-bold text-primary-300">${{ property.price|number_format }}</p>
             </div>
             <button class="bg-primary-300 px-10 py-4 rounded-full shadow-lg shadow-primary-300/30 text-white font-rubik-bold text-lg hover:bg-primary-300/90 transition-all transform active:scale-95">
                Booking Now
             </button>
        </div>
    </div>
</main>
{% endblock %}
