{% extends 'admin/base.html.twig' %}

{% block title %}Edit Property // Real Scout Admin{% endblock %}

{% block header_title %}<h1>Edit Listing Moderation</h1>{% endblock %}

{% block extra_css %}
    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 8px; font-weight: 500; font-size: 14px; color: var(--text-dim); }
    .form-control { width: 100%; padding: 12px; border-radius: 12px; border: 1px solid var(--border); font-family: var(--font-main); outline: none; }
    .form-control:focus { border-color: var(--primary); }
    textarea.form-control { height: 120px; resize: vertical; }
    
    .amenities-admin { display:grid; grid-template-columns:repeat(4, 1fr); gap:12px; margin-top:8px; }
    .amenity-item { position:relative; }
    .amenity-item input[type="checkbox"] { position:absolute; opacity:0; width:0; height:0; }
    .amenity-label { display:flex; flex-direction:column; align-items:center; gap:6px; padding:14px 8px; background:var(--bg); border:2px solid transparent; border-radius:14px; cursor:pointer; transition:all 0.3s; text-align:center; }
    .amenity-label:hover { border-color:rgba(0,122,255,0.2); }
    .amenity-item input[type="checkbox"]:checked + .amenity-label { background:rgba(0,122,255,0.1); border-color:var(--primary); }
    .amenity-icon { width:44px; height:44px; border-radius:50%; background:rgba(0,122,255,0.1); display:flex; align-items:center; justify-content:center; transition:all 0.3s; }
    .amenity-item input[type="checkbox"]:checked + .amenity-label .amenity-icon { background:var(--primary); }
    .amenity-icon img { width:22px; height:22px; transition:filter 0.3s; }
    .amenity-item input[type="checkbox"]:checked + .amenity-label .amenity-icon img { filter:brightness(10); }
    .amenity-name { font-size:11px; color:var(--text-dim); }
    .amenity-item input[type="checkbox"]:checked + .amenity-label .amenity-name { color:var(--primary); font-weight:600; }
{% endblock %}

{% block body %}
<div class="grid">
    <div class="card" style="grid-column: span 12;">
        <h3 style="margin-bottom: 25px; font-size: 18px;">Listing Details & Meta Data</h3>
        
        {{ form_start(form) }}
            <div class="form-grid">
                <div class="form-group">
                    {{ form_label(form.title) }}
                    {{ form_widget(form.title, {'attr': {'class': 'form-control'}}) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.category) }}
                    {{ form_widget(form.category, {'attr': {'class': 'form-control'}}) }}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.address) }}
                {{ form_widget(form.address, {'attr': {'class': 'form-control'}}) }}
            </div>

            <div class="form-grid" style="grid-template-columns: 1fr 1fr 1fr;">
                <div class="form-group">
                    {{ form_label(form.city) }}
                    {{ form_widget(form.city, {'attr': {'class': 'form-control'}}) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.state) }}
                    {{ form_widget(form.state, {'attr': {'class': 'form-control'}}) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.price) }}
                    {{ form_widget(form.price, {'attr': {'class': 'form-control'}}) }}
                </div>
            </div>

            <div class="form-grid" style="grid-template-columns: 1fr 1fr 1fr 1fr;">
                <div class="form-group">
                    {{ form_label(form.area) }}
                    {{ form_widget(form.area, {'attr': {'class': 'form-control'}}) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.bedrooms) }}
                    {{ form_widget(form.bedrooms, {'attr': {'class': 'form-control'}}) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.bathrooms) }}
                    {{ form_widget(form.bathrooms, {'attr': {'class': 'form-control'}}) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.kitchens) }}
                    {{ form_widget(form.kitchens, {'attr': {'class': 'form-control'}}) }}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control'}}) }}
            </div>



            <div class="form-group">
                {{ form_label(form.imageFile) }}
                {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                <div style="margin-top: 10px;">
                    <img src="{{ asset(property.image) }}" style="height: 100px; border-radius: 8px;">
                </div>
            </div>

            <div class="form-group">
                <label style="display:block; margin-bottom:8px; font-weight:500; font-size:14px; color:var(--text-dim);">Amenities</label>
                <div class="amenities-admin">
                    {% set amenity_icons = {
                        'wifi': 'icons/wifi.png', 'parking': 'icons/car-park.png', 'pool': 'icons/swim.png', 'ac': 'icons/snowflake.svg',
                        'heating': 'icons/flame.svg', 'washer': 'icons/laundry.png', 'dryer': 'icons/dryer.svg',
                        'balcony': 'icons/balcony.svg', 'garden': 'icons/garden.svg', 'gym': 'icons/dumbell.png',
                        'security': 'icons/shield.png', 'pet_friendly': 'icons/dog.png'
                    } %}
                    {% for child in form.amenities %}
                        <div class="amenity-item">
                            {{ form_widget(child) }}
                            <label class="amenity-label" for="{{ child.vars.id }}">
                                <div class="amenity-icon"><img src="{{ asset(amenity_icons[child.vars.value] | default('icons/star.png')) }}"></div>
                                <span class="amenity-name">{{ child.vars.label }}</span>
                            </label>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <div style="display: flex; gap: 12px; margin-top: 30px; border-top: 1px solid var(--border); padding-top: 30px;">
                <button type="submit" class="btn">Update Listing</button>
                <a href="{{ path('app_admin_properties') }}" class="btn" style="background: transparent; border: 1.5px solid var(--border); color: var(--text-dim); text-decoration: none; display: flex; align-items: center; justify-content: center;">Discard Changes</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% block javascripts %}
{{ parent() }}
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const addressInput = document.getElementById('property_address');
        const latInput = document.getElementById('property_latitude');
        const lngInput = document.getElementById('property_longitude');
        let geocodeTimeout;

        if (addressInput && latInput && lngInput) {
            addressInput.addEventListener('input', function() {
                clearTimeout(geocodeTimeout);
                const query = this.value;
                if (query.length < 5) return;

                geocodeTimeout = setTimeout(() => {
                    fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&limit=1`)
                        .then(response => response.json())
                        .then(data => {
                            if (data && data.length > 0) {
                                latInput.value = parseFloat(data[0].lat).toFixed(6);
                                lngInput.value = parseFloat(data[0].lon).toFixed(6);
                                addressInput.style.borderColor = '#007AFF';
                            }
                        })
                        .catch(err => console.error('Geocoding error:', err));
                }, 1000);
            });
        }
    });
</script>
{% endblock %}
