{% extends 'admin/base.html.twig' %}

{% block title %}User Operations // Real Scout Admin{% endblock %}

{% block header_title %}<h1>User Operations</h1>{% endblock %}

{% block body %}
<div class="grid">
    <div class="card" style="grid-column: span 12;">
        <h3 style="margin-bottom: 25px; font-size: 18px;">Manage System Access</h3>
        <table>
            <thead>
                <tr>
                    <th>User Details</th>
                    <th>Status & Access</th>
                    <th style="text-align: right;">Action</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr>
                    <td>
                        <div style="font-weight: 600; font-size: 15px;">{{ user.name }}</div>
                        <div style="font-size: 12px; color: var(--text-dim);">{{ user.email }}</div>
                    </td>
                    <td>
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <span style="text-transform: capitalize; font-size: 13px; font-weight: 500;">{{ user.userType }}</span>
                            {% if 'ROLE_ADMIN' in user.roles %}
                                <span style="font-size: 10px; padding: 2px 8px; background: var(--primary); color: white; border-radius: 50px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">ADMIN</span>
                            {% endif %}
                        </div>
                    </td>
                    <td style="text-align: right; display: flex; gap: 8px; justify-content: flex-end;">
                        <a href="{{ path('app_admin_user_edit', {id: user.id}) }}" class="btn" style="padding: 8px 16px; font-size: 12px; background: var(--primary-bg); color: var(--primary); text-decoration: none;">Edit</a>
                        
                        <form action="{{ path('app_admin_user_toggle_role', {id: user.id}) }}" method="POST">
                            <button type="submit" class="btn" style="padding: 8px 16px; font-size: 12px; background: {{ 'ROLE_ADMIN' in user.roles ? '#F75555' : 'var(--primary)' }};">
                                {{ 'ROLE_ADMIN' in user.roles ? 'Revoke Admin' : 'Make Admin' }}
                            </button>
                        </form>
                        {% if user != app.user %}
                        <form action="{{ path('app_admin_user_delete', {id: user.id}) }}" method="POST" onsubmit="return confirm('Purge this user node?');">
                            <button type="submit" class="btn" style="padding: 8px 16px; font-size: 12px; background: transparent; border: 1.5px solid #EF4444; color: #EF4444;">Delete</button>
                        </form>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
