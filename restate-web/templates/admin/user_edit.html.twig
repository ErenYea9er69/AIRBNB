{% extends 'admin/base.html.twig' %}

{% block title %}Edit User // Real Scout Admin{% endblock %}

{% block header_title %}<h1>Edit User Node</h1>{% endblock %}

{% block extra_css %}
    .form-group {
        margin-bottom: 20px;
    }
    .form-group label {
        display: block;
        font-size: 14px;
        font-weight: 500;
        margin-bottom: 8px;
        color: var(--text-dim);
    }
    .form-control {
        width: 100%;
        padding: 12px 16px;
        border-radius: 12px;
        border: 1px solid var(--border);
        font-family: var(--font-main);
        font-size: 14px;
        outline: none;
        transition: border-color 0.2s;
    }
    .form-control:focus {
        border-color: var(--primary);
    }
    .role-selection {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 5px;
    }
    .role-checkbox {
        display: none;
    }
    .role-label {
        padding: 8px 16px;
        border-radius: 50px;
        border: 1.5px solid var(--border);
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        color: var(--text-dim);
    }
    .role-checkbox:checked + .role-label {
        background: var(--primary);
        border-color: var(--primary);
        color: white;
    }
{% endblock %}

{% block body %}
<div class="grid">
    <div class="card" style="grid-column: span 8;">
        <h3 style="margin-bottom: 25px; font-size: 18px;">Update Identity & Permissions</h3>
        
        <form action="{{ path('app_admin_user_edit', {id: user.id}) }}" method="POST">
            <div class="form-group">
                <label for="name">Full Name</label>
                <input type="text" id="name" name="name" class="form-control" value="{{ user.name }}" required>
            </div>

            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" class="form-control" value="{{ user.email }}" required>
            </div>

            <div class="form-group">
                <label for="password">Reset Password <span style="font-size: 11px; font-weight: 400; color: var(--text-dim);">(Leave blank to keep current)</span></label>
                <input type="password" id="password" name="password" class="form-control" placeholder="Enter new password">
            </div>

            <div class="form-group">
                <label for="user_type">Account Type</label>
                <select id="user_type" name="user_type" class="form-control">
                    <option value="buyer" {{ user.userType == 'buyer' ? 'selected' : '' }}>Buyer</option>
                    <option value="seller" {{ user.userType == 'seller' ? 'selected' : '' }}>Seller (Agent)</option>
                </select>
            </div>

            <div class="form-group">
                <label>System Roles</label>
                <div class="role-selection">
                    <input type="checkbox" id="role_user" name="roles[]" value="ROLE_USER" class="role-checkbox" {{ 'ROLE_USER' in user.roles ? 'checked' : '' }}>
                    <label for="role_user" class="role-label">ROLE_USER</label>

                    <input type="checkbox" id="role_seller" name="roles[]" value="ROLE_SELLER" class="role-checkbox" {{ 'ROLE_SELLER' in user.roles ? 'checked' : '' }}>
                    <label for="role_seller" class="role-label">ROLE_SELLER</label>

                    <input type="checkbox" id="role_admin" name="roles[]" value="ROLE_ADMIN" class="role-checkbox" {{ 'ROLE_ADMIN' in user.roles ? 'checked' : '' }}>
                    <label for="role_admin" class="role-label">ROLE_ADMIN</label>
                </div>
            </div>

            <div style="display: flex; gap: 12px; margin-top: 30px;">
                <button type="submit" class="btn">Save Changes</button>
                <a href="{{ path('app_admin_users') }}" class="btn" style="background: transparent; border: 1.5px solid var(--border); color: var(--text-dim); text-decoration: none; display: flex; align-items: center; justify-content: center;">Cancel</a>
            </div>
        </form>
    </div>

    <div class="card" style="grid-column: span 4;">
        <h3 style="margin-bottom: 25px; font-size: 18px;">Account Overview</h3>
        <div style="display: flex; flex-direction: column; align-items: center; gap: 15px;">
            <img src="{{ asset(user.avatar|default('images/avatar.png')) }}" style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 4px solid var(--primary-bg);">
            <div style="text-align: center;">
                <div style="font-weight: 700; font-size: 20px;">{{ user.name }}</div>
                <div style="color: var(--text-dim); font-size: 14px;">{{ user.email }}</div>
            </div>
        </div>
        
        <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid var(--border);">
            <div style="font-size: 13px; margin-bottom: 15px;">
                <span style="color: var(--text-dim);">Properties Listed:</span>
                <span style="font-weight: 600; float: right;">{{ user.agent ? user.agent.properties|length : 0 }}</span>
            </div>
            <div style="font-size: 13px; margin-bottom: 15px;">
                <span style="color: var(--text-dim);">Total Bookings:</span>
                <span style="font-weight: 600; float: right;">{{ user.bookings|length }}</span>
            </div>
            <div style="font-size: 13px;">
                <span style="color: var(--text-dim);">Saved Items:</span>
                <span style="font-weight: 600; float: right;">{{ user.savedProperties|length }}</span>
            </div>
        </div>
    </div>
</div>
{% endblock %}
