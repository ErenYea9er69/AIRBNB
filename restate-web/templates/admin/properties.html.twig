{% extends 'admin/base.html.twig' %}

{% block title %}Property Registry // Real Scout Admin{% endblock %}

{% block header_title %}<h1>Property Registry</h1>{% endblock %}

{% block body %}
<div class="grid">
    <div class="card" style="grid-column: span 12;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
            <h3 style="font-size: 18px;">Platform Listings</h3>
            
            <form action="{{ path('app_admin_properties') }}" method="GET" style="display: flex; gap: 10px;">
                <select name="category" class="btn" style="background: var(--surface); color: var(--text-main); border: 1px solid var(--border); padding: 8px 15px;">
                    <option value="">All Categories</option>
                    {% for cat in categories %}
                        <option value="{{ cat.id }}" {{ currentCategory == cat.id ? 'selected' : '' }}>{{ cat.name }}</option>
                    {% endfor %}
                </select>
                <button type="submit" class="btn" style="padding: 8px 20px;">Filter</button>
                {% if currentCategory %}
                    <a href="{{ path('app_admin_properties') }}" class="btn" style="background: var(--primary-bg); color: var(--primary); padding: 8px 20px; text-decoration: none;">Clear</a>
                {% endif %}
            </form>
        </div>
        <table>
            <thead>
                <tr>
                    <th>Listing</th>
                    <th>Category</th>
                    <th>Agent</th>
                    <th>Location</th>
                    <th>Value</th>
                    <th>Status</th>
                    <th style="text-align: right;">Moderation</th>
                </tr>
            </thead>
            <tbody>
                {% for property in properties %}
                <tr>
                    <td>
                        <div style="font-weight: 600; font-size: 15px;">{{ property.title }}</div>
                    </td>
                    <td>
                        <span style="font-size: 12px; padding: 4px 10px; background: #f0f4ff; color: var(--primary); border-radius: 50px; font-weight: 600;">{{ property.category.name|default('Uncategorized') }}</span>
                    </td>
                    <td>
                        <div style="font-size: 14px;">{{ property.agent.name }}</div>
                    </td>
                    <td style="color: var(--text-dim);">
                        {{ property.city }}, {{ property.state }}
                    </td>
                    <td style="font-weight: 600; color: var(--primary);">
                        ${{ property.price|number_format }}
                    </td>
                    <td>
                        <span style="font-size: 11px; padding: 4px 10px; background: var(--primary-bg); color: var(--primary); border-radius: 50px; font-weight: 600;">{{ property.status|upper }}</span>
                    </td>
                    <td style="text-align: right; display: flex; gap: 8px; justify-content: flex-end;">
                        <a href="{{ path('app_admin_property_edit', {id: property.id}) }}" class="btn" style="padding: 8px 16px; font-size: 12px; background: var(--primary-bg); color: var(--primary); text-decoration: none;">EDIT</a>
                        <form action="{{ path('app_admin_property_delete', {id: property.id}) }}" method="POST" onsubmit="return confirm('WARNING: This will permanently remove this listing. Continue?');">
                            <button type="submit" class="btn" style="background: #F75555; padding: 8px 16px; font-size: 12px;">DELETE</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}