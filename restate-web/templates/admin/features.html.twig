{% extends 'admin/base.html.twig' %}

{% block title %}Features // Real Scout Admin{% endblock %}

{% block header_title %}<h1>Property Features</h1>{% endblock %}

{% block body %}
<div class="grid">
    <div class="card" style="grid-column: span 4;">
        <h3 style="margin-bottom: 20px; font-size: 18px;">Add Feature</h3>
        <form action="{{ path('app_admin_features') }}" method="POST">
            <div style="margin-bottom: 20px;">
                <label style="display: block; font-size: 13px; color: var(--text-dim); margin-bottom: 8px;">Feature Name</label>
                <input type="text" name="name" required style="width: 100%; border: 1.5px solid var(--border); border-radius: 12px; padding: 12px; font-family: var(--font-main); outline: none;">
            </div>
            <button type="submit" class="btn" style="width: 100%; padding: 14px;">Save Feature</button>
        </form>
    </div>

    <div class="card" style="grid-column: span 8;">
        <h3 style="margin-bottom: 20px; font-size: 18px;">System Attributes</h3>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px;">
            {% for feature in features %}
            <div style="padding: 15px; border: 1.5px solid var(--border); border-radius: 12px; transition: all 0.2s; position: relative;">
                <div style="font-weight: 600; font-size: 14px; margin-bottom: 4px;">{{ feature.name }}</div>
                <div style="font-size: 11px; color: var(--text-dim);">Internal Tag</div>
                <form action="{{ path('app_admin_feature_delete', {id: feature.id}) }}" method="POST" onsubmit="return confirm('Purge this attribute?');" style="position: absolute; top: 10px; right: 10px;">
                    <button type="submit" style="background: transparent; border: none; color: #EF4444; font-size: 10px; cursor: pointer;">✕</button>
                </form>
            </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}
