{% extends 'base.html.twig' %}

{% block title %}Seller Dashboard - Real Scout{% endblock %}

{% block body %}
<main class="max-w-7xl mx-auto px-6 py-10 pb-32 md:pb-10">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-rubik-bold text-black-300">Seller Dashboard</h1>
        <a href="{{ path('app_seller_property_new') }}" class="bg-primary-300 text-white px-4 py-2 rounded-full font-rubik-medium shadow-sm hover:opacity-90">Add Property</a>
    </div>

    <div class="mt-8 bg-accent-100 rounded-2xl p-6 shadow-sm border border-primary-200">
        <div class="flex items-center gap-4">
            <img src="{{ asset(agent.avatar|default('images/avatar.png')) }}" class="w-16 h-16 rounded-full object-cover">
            <div>
                <h2 class="text-lg font-rubik-bold text-black-300">{{ agent.name }}</h2>
                <p class="text-sm font-rubik text-black-200">{{ agent.email }}</p>
            </div>
        </div>
    </div>

    <h2 class="text-xl font-rubik-bold text-black-300 mt-10">My Properties</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-4">
        {% for item in properties %}
             <div class="flex flex-col items-start bg-white rounded-2xl p-4 shadow-sm border border-gray-100">
                 <div class="w-full h-40 relative rounded-xl overflow-hidden">
                      <img src="{{ asset(item.image) }}" alt="property" class="w-full h-full object-cover">
                      <div class="absolute top-3 right-3 bg-white px-2 py-1 rounded-md text-xs font-rubik-bold shadow-sm uppercase tracking-wider {{ item.status == 'available' ? 'text-green-500' : 'text-gray-500' }}">
                          {{ item.status }}
                      </div>
                 </div>

                 <div class="mt-3 w-full">
                     <h3 class="text-base font-rubik-bold text-black-300 line-clamp-1">{{ item.title }}</h3>
                     <p class="text-xs font-rubik text-black-100 mt-1 line-clamp-1">{{ item.address }}</p>
                     
                     <div class="flex flex-row items-center justify-between w-full mt-3">
                         <p class="text-base font-rubik-bold text-primary-300">${{ item.price|number_format }}</p>
                         <a href="{{ path('app_property_show', {id: item.id}) }}" class="text-sm text-primary-300 font-rubik-medium">View</a>
                     </div>
                 </div>
             </div>
        {% else %}
             <p class="text-black-100 italic col-span-full">You haven't listed any properties yet.</p>
        {% endfor %}
    </div>
</main>
{% endblock %}
