{% extends 'base.html.twig' %}

{% block title %}{{ is_edit|default(false) ? 'Edit' : 'Add' }} Property - Real Scout{% endblock %}

{% block body %}
<style>
    .form-page { max-width:800px; margin:0 auto; padding:40px 48px; }
    .form-card { background:white; border-radius:24px; padding:40px; border:1px solid rgba(0,97,255,0.06); box-shadow:0 4px 24px rgba(0,0,0,0.04); }
    .form-title { font-family:'Rubik-Bold',sans-serif; font-size:28px; font-weight:700; color:#191D31; margin:0 0 8px; }
    .form-subtitle { font-family:'Rubik',sans-serif; font-size:15px; color:#8C8E98; margin:0 0 40px; }

    .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
    .form-full { grid-column:span 2; }

    .form-field { margin-bottom:24px; }
    .form-label { display:block; font-family:'Rubik-Medium',sans-serif; font-size:13px; color:#666876; margin-bottom:8px; text-transform:uppercase; letter-spacing:0.5px; }
    .form-input { width:100%; padding:14px 18px; background:#f8f9fc; border:1.5px solid rgba(0,97,255,0.08); border-radius:14px; font-family:'Rubik',sans-serif; font-size:15px; color:#191D31; outline:none; transition:all 0.25s; box-sizing:border-box; }
    .form-input:focus { border-color:#0061FF; background:white; box-shadow:0 0 0 4px rgba(0,97,255,0.08); }
    
    .form-btn { display:inline-flex; align-items:center; gap:8px; padding:16px 40px; background:#0061FF; color:white; border-radius:14px; font-family:'Rubik-Bold',sans-serif; font-size:16px; border:none; cursor:pointer; transition:all 0.3s; box-shadow:0 6px 20px rgba(0,97,255,0.3); margin-top:20px; }
    .form-btn:hover { background:#0050d4; transform:translateY(-1px); }

    .help-text { font-family:'Rubik',sans-serif; font-size:12px; color:#8C8E98; margin-top:6px; }

    @media (max-width:768px) {
        .form-grid { grid-template-columns:1fr; }
        .form-full { grid-column:span 1; }
    }
</style>

<div class="form-page">
    <a href="{{ path('app_seller_dashboard') }}" style="display:inline-flex; align-items:center; gap:8px; text-decoration:none; color:#8C8E98; font-family:'Rubik-Medium',sans-serif; margin-bottom:24px; font-size:14px;">
        <img src="{{ asset('icons/back-arrow.png') }}" style="width:14px; height:14px; opacity:0.5;">
        Back to Dashboard
    </a>

    <div class="form-card">
        {% block form_header %}
            <div style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:40px;">
                <div>
                    <h1 class="form-title">Property Form</h1>
                    <p class="form-subtitle" style="margin-bottom:0;">Fill in the details below to list your property.</p>
                </div>
                {% if not is_edit|default(false) %}
                    <button type="button" id="magic-fill" class="form-btn" style="background:rgba(0,97,255,0.08); color:#0061FF; box-shadow:none; margin-top:0; padding:10px 20px; font-size:13px; border:1px solid rgba(0,97,255,0.15);">
                        ✨ Magic Fill
                    </button>
                {% endif %}
            </div>
        {% endblock %}

        {% if not form.vars.valid %}
            <div style="padding:16px 20px; border-radius:12px; background:rgba(247,85,85,0.08); color:#F75555; border:1px solid rgba(247,85,85,0.15); margin-bottom:24px; font-family:'Rubik-Medium',sans-serif; font-size:14px;">
                <p style="margin:0 0 8px; font-weight:700;">Please fix the following errors:</p>
                {{ form_errors(form) }}
            </div>
        {% endif %}

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            <div class="form-grid">
                <div class="form-field form-full">
                    <label class="form-label">Property Title</label>
                    {{ form_widget(form.title, {'attr': {'class': 'form-input', 'placeholder': 'e.g. Modern Villa with Pool'}}) }}
                    <div style="color:#F75555; font-size:12px; margin-top:4px;">{{ form_errors(form.title) }}</div>
                </div>
                <div class="form-field form-full">
                    <label class="form-label">Full Address</label>
                    {{ form_widget(form.address, {'attr': {'class': 'form-input', 'placeholder': 'e.g. 123 Luxury Ave'}}) }}
                    <div style="color:#F75555; font-size:12px; margin-top:4px;">{{ form_errors(form.address) }}</div>
                </div>
                <div class="form-field">
                    <label class="form-label">City</label>
                    {{ form_widget(form.city, {'attr': {'class': 'form-input', 'placeholder': 'e.g. Los Angeles'}}) }}
                </div>
                <div class="form-field">
                    <label class="form-label">State / Region</label>
                    {{ form_widget(form.state, {'attr': {'class': 'form-input', 'placeholder': 'e.g. CA'}}) }}
                </div>
                <div class="form-field">
                    <label class="form-label">Price ($)</label>
                    {{ form_widget(form.price, {'attr': {'class': 'form-input', 'placeholder': 'e.g. 250000'}}) }}
                </div>
                <div class="form-field">
                    <label class="form-label">Category</label>
                    {{ form_widget(form.category, {'attr': {'class': 'form-input'}}) }}
                </div>
                <div class="form-field">
                    <label class="form-label">Bedrooms</label>
                    {{ form_widget(form.bedrooms, {'attr': {'class': 'form-input'}}) }}
                </div>
                <div class="form-field">
                    <label class="form-label">Bathrooms</label>
                    {{ form_widget(form.bathrooms, {'attr': {'class': 'form-input'}}) }}
                </div>
                <div class="form-field">
                    <label class="form-label">Area (sqft)</label>
                    {{ form_widget(form.area, {'attr': {'class': 'form-input', 'placeholder': 'e.g. 2400'}}) }}
                </div>
                <div class="form-field">
                    <label class="form-label">Listing Type</label>
                    {{ form_widget(form.listingType, {'attr': {'class': 'form-input'}}) }}
                </div>
                <div class="form-field">
                    <label class="form-label">Latitude</label>
                    {{ form_widget(form.latitude, {'attr': {'class': 'form-input', 'placeholder': 'e.g. 34.0522'}}) }}
                </div>
                <div class="form-field">
                    <label class="form-label">Longitude</label>
                    {{ form_widget(form.longitude, {'attr': {'class': 'form-input', 'placeholder': 'e.g. -118.2437'}}) }}
                </div>
                <div class="form-field form-full">
                    <label class="form-label">Description</label>
                    {{ form_widget(form.description, {'attr': {'class': 'form-input', 'style': 'height:120px; resize:none;', 'placeholder': 'Tell buyers more about this property...'}}) }}
                </div>
                <div class="form-field form-full">
                    <label class="form-label">Property Main Image</label>
                    {{ form_widget(form.imageFile, {'attr': {'class': 'form-input'}}) }}
                    <div style="color:#F75555; font-size:12px; margin-top:4px;">{{ form_errors(form.imageFile) }}</div>
                    <p class="help-text">Upload a high-quality main image for your listing. JPG, PNG or WEBP (Max 5MB).</p>
                </div>
                <div class="form-field form-full">
                    <label class="form-label">Gallery Images</label>
                    {{ form_widget(form.galleryFiles, {'attr': {'class': 'form-input'}}) }}
                    <p class="help-text">Select multiple images to show more details of your property.</p>
                </div>
                <div class="form-field form-full">
                    <label class="form-label">Property Features (Amenities)</label>
                    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(140px, 1fr)); gap:12px; background:#f8f9fc; padding:20px; border-radius:14px; border:1.5px solid rgba(0,97,255,0.05);">
                        {% for feature_field in form.features %}
                            <label style="display:flex; align-items:center; gap:8px; cursor:pointer; font-family:'Rubik',sans-serif; font-size:14px; color:#191D31;">
                                {{ form_widget(feature_field) }}
                                {{ feature_field.vars.label }}
                            </label>
                        {% endfor %}
                    </div>
                </div>
                <div class="form-field">
                    <label class="form-label">Availability Status</label>
                    {{ form_widget(form.status, {'attr': {'class': 'form-input'}}) }}
                </div>
            </div>

            <button type="submit" class="form-btn">
                {{ is_edit|default(false) ? 'Update Listing' : 'Publish Property' }}
            </button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    const initMagicFill = () => {
        const btn = document.getElementById('magic-fill');
        if (!btn) return;

        btn.addEventListener('click', () => {
            const data = {
                'property_title': 'Luxury Penthouse with Skyline View',
                'property_address': '789 Diamond District, Manhattan',
                'property_city': 'New York',
                'property_state': 'NY',
                'property_price': '1250000',
                'property_area': '3200',
                'property_bedrooms': '4',
                'property_bathrooms': '3',
                'property_description': 'Experience the pinnacle of urban living in this breathtaking penthouse. Featuring floor-to-ceiling windows, a private terrace, and state-of-the-art appliances, this residence offers unparalleled luxury in the heart of the city.',
                'property_latitude': '40.7128',
                'property_longitude': '-74.0060',
                'property_listingType': 'sale',
                'property_status': 'available'
            };

            for (const [id, value] of Object.entries(data)) {
                const el = document.getElementById(id);
                if (el) el.value = value;
            }

            // Randomly select a category if not already set
            const catSelect = document.getElementById('property_category');
            if (catSelect && (catSelect.value === "" || catSelect.selectedIndex <= 0)) {
                const options = Array.from(catSelect.options).filter(o => o.value !== "");
                if (options.length > 0) {
                    const randomOption = options[Math.floor(Math.random() * options.length)];
                    catSelect.value = randomOption.value;
                }
            }

            // Randomly check some features
            const features = document.querySelectorAll('input[name="property[features][]"]');
            features.forEach(f => {
                f.checked = Math.random() > 0.5;
            });

            // Visual feedback
            const originalText = btn.innerHTML;
            btn.innerHTML = '✅ Filled!';
            btn.style.background = 'rgba(34, 197, 94, 0.08)';
            btn.style.color = '#22c55e';
            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.style.background = 'rgba(0, 97, 255, 0.08)';
                btn.style.color = '#0061FF';
            }, 2000);
        });
    };

    document.addEventListener('DOMContentLoaded', initMagicFill);
    document.addEventListener('turbo:load', initMagicFill);
</script>
{% endblock %}
