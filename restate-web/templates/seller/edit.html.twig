{% extends 'base.html.twig' %}

{% block title %}Edit Property - Real Scout{% endblock %}

{% block body %}
<main class="max-w-3xl mx-auto px-6 py-10 pb-32">
    <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-4">
            <a href="{{ path('app_seller_dashboard') }}" class="bg-primary-200 w-10 h-10 rounded-full flex items-center justify-center hover:opacity-80">
                <img src="{{ asset('icons/back-arrow.png') }}" class="w-4 h-4 opacity-70">
            </a>
            <h1 class="text-2xl font-rubik-bold text-black-300">Edit Property</h1>
        </div>

        <form method="post" action="{{ path('app_seller_property_delete', {'id': property.id}) }}" onsubmit="return confirm('Are you sure you want to delete this property?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ property.id) }}">
            <button class="bg-red-50 text-red-500 px-4 py-2 rounded-full font-rubik-medium shadow-sm hover:bg-red-100 transition-colors flex items-center gap-2">
                Delete
            </button>
        </form>
    </div>

    {{ form_start(form, {'attr': {'class': 'flex flex-col gap-6 bg-white p-6 rounded-3xl shadow-sm border border-gray-100'}}) }}

        <div class="flex flex-col gap-2">
            {{ form_label(form.title, 'Property Title', {'label_attr': {'class': 'text-sm font-rubik-medium text-black-300 ml-1'}}) }}
            {{ form_widget(form.title, {'attr': {'class': 'bg-gray-50 border border-gray-100 rounded-xl px-4 py-3 outline-none focus:border-primary-300 font-rubik text-sm'}}) }}
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2">
                {{ form_label(form.listingType, 'Listing Type', {'label_attr': {'class': 'text-sm font-rubik-medium text-black-300 ml-1'}}) }}
                {{ form_widget(form.listingType, {'attr': {'class': 'bg-gray-50 border border-gray-100 rounded-xl px-4 py-3 outline-none focus:border-primary-300 font-rubik text-sm'}}) }}
            </div>
            <div class="flex flex-col gap-2">
                {{ form_label(form.category, 'Category', {'label_attr': {'class': 'text-sm font-rubik-medium text-black-300 ml-1'}}) }}
                {{ form_widget(form.category, {'attr': {'class': 'bg-gray-50 border border-gray-100 rounded-xl px-4 py-3 outline-none focus:border-primary-300 font-rubik text-sm'}}) }}
            </div>
        </div>

        <div class="flex flex-col gap-2">
            {{ form_label(form.address, 'Address', {'label_attr': {'class': 'text-sm font-rubik-medium text-black-300 ml-1'}}) }}
            {{ form_widget(form.address, {'attr': {'class': 'bg-gray-50 border border-gray-100 rounded-xl px-4 py-3 outline-none focus:border-primary-300 font-rubik text-sm'}}) }}
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="flex flex-col gap-2">
                {{ form_label(form.city, 'City', {'label_attr': {'class': 'text-sm font-rubik-medium text-black-300 ml-1'}}) }}
                {{ form_widget(form.city, {'attr': {'class': 'bg-gray-50 border border-gray-100 rounded-xl px-4 py-3 outline-none focus:border-primary-300 font-rubik text-sm'}}) }}
            </div>
            <div class="flex flex-col gap-2">
                {{ form_label(form.state, 'State', {'label_attr': {'class': 'text-sm font-rubik-medium text-black-300 ml-1'}}) }}
                {{ form_widget(form.state, {'attr': {'class': 'bg-gray-50 border border-gray-100 rounded-xl px-4 py-3 outline-none focus:border-primary-300 font-rubik text-sm'}}) }}
            </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            <div class="flex flex-col gap-2">
                {{ form_label(form.price, 'Price ($)', {'label_attr': {'class': 'text-sm font-rubik-medium text-black-300 ml-1'}}) }}
                {{ form_widget(form.price, {'attr': {'class': 'bg-gray-50 border border-gray-100 rounded-xl px-4 py-3 outline-none focus:border-primary-300 font-rubik text-sm'}}) }}
            </div>
            <div class="flex flex-col gap-2">
                {{ form_label(form.area, 'Area (sqft)', {'label_attr': {'class': 'text-sm font-rubik-medium text-black-300 ml-1'}}) }}
                {{ form_widget(form.area, {'attr': {'class': 'bg-gray-50 border border-gray-100 rounded-xl px-4 py-3 outline-none focus:border-primary-300 font-rubik text-sm'}}) }}
            </div>
            <div class="flex flex-col gap-2">
                {{ form_label(form.bedrooms, 'Bedrooms', {'label_attr': {'class': 'text-sm font-rubik-medium text-black-300 ml-1'}}) }}
                {{ form_widget(form.bedrooms, {'attr': {'class': 'bg-gray-50 border border-gray-100 rounded-xl px-4 py-3 outline-none focus:border-primary-300 font-rubik text-sm'}}) }}
            </div>
            <div class="flex flex-col gap-2">
                {{ form_label(form.bathrooms, 'Bathrooms', {'label_attr': {'class': 'text-sm font-rubik-medium text-black-300 ml-1'}}) }}
                {{ form_widget(form.bathrooms, {'attr': {'class': 'bg-gray-50 border border-gray-100 rounded-xl px-4 py-3 outline-none focus:border-primary-300 font-rubik text-sm'}}) }}
            </div>
        </div>

        <div class="flex flex-col gap-2">
            {{ form_label(form.status, 'Property Status', {'label_attr': {'class': 'text-sm font-rubik-medium text-black-300 ml-1'}}) }}
            {{ form_widget(form.status, {'attr': {'class': 'bg-gray-50 border border-gray-100 rounded-xl px-4 py-3 outline-none focus:border-primary-300 font-rubik text-sm'}}) }}
        </div>

        <div class="flex flex-col gap-2">
            {{ form_label(form.imageFile, 'Upload New Property Image (Optional)', {'label_attr': {'class': 'text-sm font-rubik-medium text-black-300 ml-1'}}) }}
            {{ form_widget(form.imageFile, {'attr': {'class': 'bg-gray-50 border border-gray-100 rounded-xl px-4 py-3 outline-none focus:border-primary-300 font-rubik text-sm'}}) }}
            {{ form_errors(form.imageFile, {'attr': {'class': 'text-xs text-red-500 mt-1'}}) }}
            {% if property.image %}
                <p class="text-xs text-black-100 ml-1">Current image: <img src="{{ asset(property.image) }}" class="h-10 mt-1 rounded"></p>
            {% endif %}
        </div>

        <div class="flex flex-col gap-2">
            {{ form_label(form.description, 'Description', {'label_attr': {'class': 'text-sm font-rubik-medium text-black-300 ml-1'}}) }}
            {{ form_widget(form.description, {'attr': {'class': 'bg-gray-50 border border-gray-100 rounded-xl px-4 py-3 outline-none focus:border-primary-300 font-rubik text-sm min-h-[120px]'}}) }}
        </div>

        <div class="hidden">
            {{ form_widget(form.latitude) }}
            {{ form_widget(form.longitude) }}
        </div>

        <button type="submit" class="bg-primary-300 text-white font-rubik-bold text-lg py-4 rounded-full mt-4 shadow-lg hover:bg-primary-300/90 transition-all">
            Update Property
        </button>

    {{ form_end(form) }}
</main>
{% endblock %}
