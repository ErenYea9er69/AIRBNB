<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Real Scout{% endblock %}</title>
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🏠</text></svg>">
        
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {{ importmap('app') }}
        {% endblock %}
    </head>
    <body style="background:#f8f9fc; min-height:100vh; margin:0; font-family:'Rubik',sans-serif;">
        <div style="display:flex; flex-direction:column; min-height:100vh;">
            {% block body %}{% endblock %}
            
            {% block footer_nav %}
                {# Standard Bottom Nav for Mobile #}
                <nav style="position:fixed; bottom:0; left:0; right:0; background:white; border-top:1px solid rgba(0,97,255,0.1); padding:12px 24px; display:flex; justify-content:space-around; align-items:center; z-index:50;">
                    <a href="{{ path('app_home') }}" style="display:flex; flex-direction:column; align-items:center; text-decoration:none; color:#666876;">
                        <img src="{{ asset('icons/home.png') }}" alt="home" style="width:24px; height:24px;">
                        <span style="font-size:10px; margin-top:4px;">Home</span>
                    </a>
                    <a href="{{ path('app_explore') }}" style="display:flex; flex-direction:column; align-items:center; text-decoration:none; color:#666876;">
                        <img src="{{ asset('icons/search.png') }}" alt="explore" style="width:24px; height:24px;">
                        <span style="font-size:10px; margin-top:4px;">Explore</span>
                    </a>
                    {% if is_granted('ROLE_SELLER') %}
                    <a href="{{ path('app_seller_dashboard') }}" style="display:flex; flex-direction:column; align-items:center; text-decoration:none; color:#666876;">
                        <img src="{{ asset('icons/car-park.png') }}" alt="dashboard" style="width:24px; height:24px;">
                        <span style="font-size:10px; margin-top:4px;">Dashboard</span>
                    </a>
                    {% endif %}
                    <a href="{{ path('app_profile') }}" style="display:flex; flex-direction:column; align-items:center; text-decoration:none; color:#666876;">
                        <img src="{{ asset('icons/person.png') }}" alt="profile" style="width:24px; height:24px;">
                        <span style="font-size:10px; margin-top:4px;">Profile</span>
                    </a>
                </nav>
            {% endblock %}
        </div>
    </body>
</html>
