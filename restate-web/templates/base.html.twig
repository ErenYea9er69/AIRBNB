<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Real Scout{% endblock %}</title>
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🏠</text></svg>">
        
        {% block stylesheets %}
        {% endblock %}

        <style>
            /* Desktop Header Styles */
            .main-header {
                position: sticky;
                top: 0;
                left: 0;
                right: 0;
                background: rgba(255, 255, 255, 0.8);
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                border-bottom: 1px solid rgba(0, 97, 255, 0.08);
                padding: 14px 48px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                z-index: 100;
            }
            .header-logo {
                font-family: 'Rubik-Bold', sans-serif;
                font-size: 22px;
                color: #0061FF;
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 8px;
            }
            .header-nav {
                display: flex;
                align-items: center;
                gap: 32px;
            }
            .header-link {
                font-family: 'Rubik-Medium', sans-serif;
                font-size: 15px;
                color: #666876;
                text-decoration: none;
                transition: color 0.2s;
            }
            .header-link:hover {
                color: #0061FF;
            }
            .header-link.active {
                color: #0061FF;
            }
            .header-user {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 6px 12px;
                border-radius: 50px;
                background: #f8f9fc;
                border: 1px solid rgba(0, 97, 255, 0.05);
                text-decoration: none;
                transition: all 0.2s;
            }
            .header-user:hover {
                background: #f0f4ff;
                border-color: rgba(0, 97, 255, 0.2);
            }
            .header-avatar {
                width: 32px;
                height: 32px;
                border-radius: 50%;
                object-fit: cover;
            }

            /* Mobile Bottom Nav Styles */
            .mobile-nav {
                display: none;
                position: fixed;
                bottom: 0;
                left: 0;
                right: 0;
                background: white;
                border-top: 1px solid rgba(0, 97, 255, 0.1);
                padding: 12px 24px;
                justify-content: space-around;
                align-items: center;
                z-index: 50;
            }
            .mobile-link {
                display: flex;
                flex-direction: column;
                align-items: center;
                text-decoration: none;
                color: #8C8E98;
                gap: 4px;
            }
            .mobile-link.active {
                color: #0061FF;
            }
            .mobile-link img {
                width: 24px;
                height: 24px;
                opacity: 0.6;
            }
            .mobile-link.active img {
                opacity: 1;
                filter: none;
            }

            @media (max-width: 768px) {
                .main-header { display: none; }
                .mobile-nav { display: flex; }
                body { padding-bottom: 70px; }
            }
        </style>

        {% block javascripts %}
            {{ importmap('app') }}
        {% endblock %}
    </head>
    <body style="background:#f8f9fc; min-height:100vh; margin:0; font-family:'Rubik',sans-serif;">
        <div style="display:flex; flex-direction:column; min-height:100vh;">
            
            {# TOP HEADER (Desktop Only) #}
            {% if app.user %}
            <header class="main-header">
                <a href="{{ path('app_home') }}" class="header-logo">
                    <span>🏠</span> Real Scout
                </a>
                <nav class="header-nav">
                    <a href="{{ path('app_home') }}" class="header-link {{ app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}">Home</a>
                    <a href="{{ path('app_explore') }}" class="header-link {{ app.request.attributes.get('_route') == 'app_explore' ? 'active' : '' }}">Explore</a>
                    {% if is_granted('ROLE_SELLER') %}
                        <a href="{{ path('app_seller_dashboard') }}" class="header-link {{ app.request.attributes.get('_route') starts with 'app_seller' ? 'active' : '' }}">Dashboard</a>
                    {% endif %}
                </nav>
                <a href="{{ path('app_profile') }}" class="header-user">
                    <img src="{{ app.user.avatar|default(asset('images/japan.png')) }}" class="header-avatar">
                    <span style="font-family:'Rubik-Medium',sans-serif; font-size:14px; color:#191D31;">{{ app.user.name }}</span>
                </a>
            </header>
            {% endif %}

            <div style="flex:1;">
                {% block body %}{% endblock %}
            </div>
            
            {# BOTTOM NAV (Mobile Only) #}
            {% if app.user %}
            {% block footer_nav %}
                <nav class="mobile-nav">
                    <a href="{{ path('app_home') }}" class="mobile-link {{ app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}">
                        <img src="{{ asset('icons/home.png') }}" alt="home">
                        <span style="font-size:10px;">Home</span>
                    </a>
                    <a href="{{ path('app_explore') }}" class="mobile-link {{ app.request.attributes.get('_route') == 'app_explore' ? 'active' : '' }}">
                        <img src="{{ asset('icons/search.png') }}" alt="explore">
                        <span style="font-size:10px;">Explore</span>
                    </a>
                    {% if is_granted('ROLE_SELLER') %}
                    <a href="{{ path('app_seller_dashboard') }}" class="mobile-link {{ app.request.attributes.get('_route') starts with 'app_seller' ? 'active' : '' }}">
                        <img src="{{ asset('icons/car-park.png') }}" alt="dashboard">
                        <span style="font-size:10px;">Dashboard</span>
                    </a>
                    {% endif %}
                    <a href="{{ path('app_profile') }}" class="mobile-link {{ app.request.attributes.get('_route') == 'app_profile' ? 'active' : '' }}">
                        <img src="{{ asset('icons/person.png') }}" alt="profile">
                        <span style="font-size:10px;">Profile</span>
                    </a>
                </nav>
            {% endblock %}
            {% endif %}
        </div>
    </body>
</html>
